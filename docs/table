            text-align: center;
        }

        /* 分页控件 */
        .pagination {
            display: flex;
            justify-content: center;
            align-items: center;
            margin-top: 30px;
            gap: 10px;
        }

        .pagination button {
            background-color: white;
            border: 1px solid #ddd;
            border-radius: 5px;
            padding: 10px 15px;
            cursor: pointer;
            transition: all 0.3s;
            font-size: 1rem;
            color: #555;
        }

        .pagination button:hover:not(:disabled) {
            background-color: #1e88e5;
            color: white;
            border-color: #1e88e5;
        }

        .pagination button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .page-info {
            margin: 0 15px;
            font-size: 1rem;
            color: #666;
        }

        .page-size {
            margin-left: 30px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .page-size select {
            padding: 8px 12px;
            border-radius: 5px;
            border: 1px solid #ddd;
            background-color: white;
            font-size: 1rem;
