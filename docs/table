            padding: 30px 0 80px;
        }

        .table-container {
            background-color: white;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.07);
            margin-bottom: 40px;
            overflow-x: auto;
        }

        .movies-table {
            width: 100%;
            border-collapse: collapse;
            min-width: 1000px;
        }

        .movies-table thead {
            background-color: #2c3e50;
            color: white;
        }

        .movies-table th {
            padding: 18px 15px;
            text-align: left;
            font-weight: 600;
            font-size: 1.1rem;
            border-right: 1px solid rgba(255, 255, 255, 0.1);
        }

        .movies-table th:last-child {
            border-right: none;
        }

        .movies-table tbody tr {
            border-bottom: 1px solid #eee;
            transition: background-color 0.2s;
        }

        .movies-table tbody tr:hover {
            background-color: #f5f9ff;
        }

        .movies-table td {
            padding: 16px 15px;
            color: #555;
            vertical-align: top;
        }

        .rank-cell {
            font-weight: 700;
            color: #ff6b35;
            text-align: center;
            font-size: 1.2rem;
        }

        .title-cell {
            font-weight: 600;
            color: #2c3e50;
        }

        .rating-cell {
            color: #ff9800;
            font-weight: 600;
        }

        .year-cell {
            text-align: center;
        }

        .country-cell,
